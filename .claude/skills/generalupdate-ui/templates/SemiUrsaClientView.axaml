<!--
【Skill 自动生成】Avalonia + SemiUrsa 客户端更新窗口 — 全状态覆盖

覆盖状态：Idle | Checking | FoundUpdate | AlreadyLatest | Downloading
         Paused | DownloadError | Applying | Success | Failed | RollingBack

使用方式：
  1. 安装 NuGet: Semi.Avalonia
  2. 添加 RealDownloadService.cs（桥接 GeneralUpdate.Core 事件）
  3. 在 App.axaml.cs DI 注册：
     services.AddSingleton<IDownloadService>(sp =>
         new RealDownloadService("https://your-server.com/api", "your-key"));
  4. 设置 DataContext = new EnhancedDownloadViewModel(downloadService)
-->
<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:Client.Avalonia.ViewModels"
        xmlns:semi="https://github.com/irihitech/Semi.Avalonia"
        x:Class="Client.Avalonia.Views.UpdateWindow"
        x:DataType="vm:EnhancedDownloadViewModel"
        Title="软件更新"
        Width="520" Height="420"
        WindowStartupLocation="CenterScreen"
        CanResize="False"
        ExtendClientAreaToDecorationsHint="True"
        ExtendClientAreaChromeHints="NoChrome">

  <Window.Styles>
    <semi:SemiTheme Locale="zh-CN" />
  </Window.Styles>

  <Grid RowDefinitions="Auto,*,Auto" Margin="0">

    <!-- ═══ 标题栏 ═══ -->
    <Border Grid.Row="0" Height="48"
            Background="{DynamicResource SemiColorFillSecondaryBackgorund}">
      <Grid ColumnDefinitions="48,*,48" Margin="16,0">
        <!-- Icon -->
        <Border Grid.Column="0" CornerRadius="24"
                Background="{DynamicResource SemiColorAccentPrimary}">
          <TextBlock Text="🔄" FontSize="20"
                     HorizontalAlignment="Center"
                     VerticalAlignment="Center" />
        </Border>
        <!-- Title + Version -->
        <StackPanel Grid.Column="1" VerticalAlignment="Center" Margin="12,0,0,0">
          <TextBlock Text="软件更新" FontSize="16" FontWeight="SemiBold" />
          <TextBlock Text="{Binding VersionText}" FontSize="12"
                     Foreground="{DynamicResource SemiColorTextSecondary}"
                     Opacity="0.7" />
        </StackPanel>
      </Grid>
    </Border>

    <!-- ═══ 内容区域 ═══ -->
    <Border Grid.Row="1" Padding="32,16">
      <StackPanel Spacing="12" VerticalAlignment="Center">

        <!-- 状态文字（居中，大字） -->
        <TextBlock Text="{Binding StatusText}"
                   FontSize="20" FontWeight="SemiBold"
                   HorizontalAlignment="Center"
                   Margin="0,0,0,8" />

        <!-- ═══ 检查中（indeterminate 动画）═══ -->
        <StackPanel IsVisible="{Binding IsIndeterminate}"
                    Spacing="16" HorizontalAlignment="Center">
          <ProgressBar IsIndeterminate="True" Height="4"
                       Width="300" CornerRadius="2"
                       Foreground="{DynamicResource SemiColorAccentPrimary}" />
        </StackPanel>

        <!-- ═══ 发现新版本 ═══ -->
        <StackPanel IsVisible="{Binding IsUpdateFound}" Spacing="16">
          <Border CornerRadius="8"
                  Background="{DynamicResource SemiColorFillTertiary}"
                  Padding="16">
            <StackPanel Spacing="8">
              <TextBlock FontSize="14" FontWeight="SemiBold">
                版本 <Run Text="{Binding Statistics.Version}" />
              </TextBlock>
              <TextBlock FontSize="12"
                         Foreground="{DynamicResource SemiColorTextSecondary}">
                <Run Text="{Binding Statistics.TotalBytesToReceiveInMB, StringFormat='{0:F1} MB'}" />
              </TextBlock>
            </StackPanel>
          </Border>
          <Button Command="{Binding DownloadCommand}"
                  Content="开始更新"
                  HorizontalAlignment="Center"
                  Width="160" Height="36"
                  CornerRadius="18" />
        </StackPanel>

        <!-- ═══ 下载进度条 ═══ -->
        <StackPanel IsVisible="{Binding IsProgressVisible}" Spacing="8">
          <ProgressBar Value="{Binding Statistics.ProgressPercentage}"
                       Minimum="0" Maximum="100"
                       Height="8" CornerRadius="4"
                       Foreground="{DynamicResource SemiColorAccentPrimary}"
                       Background="{DynamicResource SemiColorFillTertiary}" />
          <Grid ColumnDefinitions="*,*">
            <TextBlock Grid.Column="0" FontSize="12"
                       Foreground="{DynamicResource SemiColorTextTertiary}">
              <Run Text="{Binding SpeedText}" />
            </TextBlock>
            <TextBlock Grid.Column="1" FontSize="12"
                       Foreground="{DynamicResource SemiColorTextTertiary}"
                       HorizontalAlignment="Right">
              <Run Text="{Binding Statistics.Remaining, StringFormat='剩余 {0:mm\\:ss}'}" />
            </TextBlock>
          </Grid>
        </StackPanel>

        <!-- ═══ 错误信息 + 重试 ═══ -->
        <StackPanel IsVisible="{Binding IsErrorVisible}" Spacing="12">
          <Border CornerRadius="8" Padding="12"
                  Background="#FFF0F0"
                  BorderBrush="#FF4444" BorderThickness="1">
            <TextBlock Text="{Binding ErrorMessage}"
                       TextWrapping="Wrap"
                       Foreground="#CC3333" FontSize="13" />
          </Border>
          <StackPanel Orientation="Horizontal"
                      HorizontalAlignment="Center" Spacing="8">
            <Button Command="{Binding RetryCommand}"
                    Content="重试" Width="100" Height="32"
                    CornerRadius="16" />
            <Button Command="{Binding CancelCommand}"
                    Content="取消" Width="80" Height="32"
                    CornerRadius="16" Background="Transparent" />
          </StackPanel>
        </StackPanel>

        <!-- ═══ 更新完成 ═══ -->
        <StackPanel IsVisible="{Binding IsCompleted}" Spacing="12"
                    HorizontalAlignment="Center">
          <Border CornerRadius="40" Width="64" Height="64"
                  Background="{DynamicResource SemiColorSuccessPrimary}">
            <TextBlock Text="✓" FontSize="32" Foreground="White"
                       HorizontalAlignment="Center"
                       VerticalAlignment="Center" />
          </Border>
          <TextBlock Text="更新完成" FontSize="18" FontWeight="SemiBold"
                     HorizontalAlignment="Center" />
          <TextBlock Text="应用即将重启" FontSize="13"
                     Foreground="{DynamicResource SemiColorTextSecondary}"
                     HorizontalAlignment="Center" />
        </StackPanel>

        <!-- ═══ 已是最新版 ═══ -->
        <StackPanel IsVisible="{Binding IsCompleted}"
                    HorizontalAlignment="Center" Spacing="8">
          <TextBlock Text="已是最新版本 ✓" FontSize="16"
                     Foreground="{DynamicResource SemiColorSuccessPrimary}"
                     HorizontalAlignment="Center" />
        </StackPanel>

      </StackPanel>
    </Border>

    <!-- ═══ 底部按钮区域 ═══ -->
    <Border Grid.Row="2" Padding="16,8"
            Background="{DynamicResource SemiColorFillSecondaryBackgorund}">
      <StackPanel Orientation="Horizontal"
                  HorizontalAlignment="Right" Spacing="8">

        <!-- 开始检查（Idle 状态，由 CanExecute 控制） -->
        <Button Command="{Binding CheckCommand}"
                Content="检查更新" Width="100" Height="32" CornerRadius="6" />

        <!-- 暂停（下载中，由 CanExecute 控制） -->
        <Button Command="{Binding PauseCommand}"
                Content="暂停" Width="80" Height="32" CornerRadius="6"
                Background="Transparent" />

      </StackPanel>
    </Border>

  </Grid>
</Window>
