<!--
【Skill 自动生成】WPF + LayUI.Wpf 更新窗口
基于 LayUI.Wpf 皮肤库，替换 MockDownloadService → RealDownloadService 即可真实驱动更新

使用方式：
  1. 安装 NuGet: LayUI.Wpf
  2. 添加 RealDownloadService_Wpf.cs（从 RealDownloadService.cs 改编）
  3. 在 App.xaml 中引用 LayUI.Wpf 主题
  4. 将本文件添加到 Views/
-->
<lui:LayWindow x:Class="Upgrade.WPF.Views.UpdateWindow"
               xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
               xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
               xmlns:lui="clr-namespace:LayUI.Wpf.Controls;assembly=LayUI.Wpf"
               xmlns:vm="clr-namespace:Upgrade.WPF.ViewModels"
               Title="软件更新"
               Height="350" Width="500"
               WindowStartupLocation="CenterScreen"
               ResizeMode="CanMinimize"
               Icon="/Resources/update.ico"
               lui:LayWindowHelper.IsTitleAcross="False">

  <Window.Resources>
    <Style TargetType="TextBlock" x:Key="InfoText">
      <Setter Property="FontSize" Value="13" />
      <Setter Property="Foreground" Value="#666666" />
      <Setter Property="Margin" Value="0,2" />
    </Style>
  </Window.Resources>

  <Grid Margin="0,0,0,0">
    <Grid.RowDefinitions>
      <RowDefinition Height="Auto" />
      <RowDefinition Height="*" />
      <RowDefinition Height="Auto" />
    </Grid.RowDefinitions>

    <!-- 标题区域 -->
    <Border Grid.Row="0" Height="60"
            Background="{DynamicResource PrimaryBrush}"
            Padding="20,0">
      <StackPanel VerticalAlignment="Center">
        <TextBlock Text="发现新版本"
                   FontSize="20" FontWeight="Bold"
                   Foreground="White" />
        <TextBlock Text="{Binding Statistics.Version, StringFormat='版本: {0}'}"
                   FontSize="13"
                   Foreground="#CCFFFFFF" />
      </StackPanel>
    </Border>

    <!-- 内容区域 -->
    <StackPanel Grid.Row="1" Margin="32,24" Spacing="16"
                VerticalAlignment="Center">

      <!-- 进度状态 -->
      <TextBlock Text="{Binding StatusText}"
                 FontSize="16" FontWeight="SemiBold"
                 HorizontalAlignment="Center" />

      <!-- 进度条 (LayUI 风格) -->
      <Border Height="8" CornerRadius="4"
              Background="#E8E8E8">
        <Border Height="8" CornerRadius="4"
                Width="{Binding Statistics.ProgressPercentage, Converter={StaticResource PercentToWidthConverter}}"
                Background="{DynamicResource PrimaryBrush}" />
      </Border>

      <!-- 统计信息 -->
      <Grid Margin="0,8,0,0">
        <Grid.ColumnDefinitions>
          <ColumnDefinition Width="*" />
          <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>
        <StackPanel Grid.Column="0">
          <TextBlock Text="下载速度"
                     Style="{StaticResource InfoText}" />
          <TextBlock Text="{Binding Statistics.Speed, StringFormat='{0:F1} MB/s'}"
                     FontSize="16" FontWeight="Bold" />
        </StackPanel>
        <StackPanel Grid.Column="1">
          <TextBlock Text="剩余时间"
                     Style="{StaticResource InfoText}"
                     HorizontalAlignment="Right" />
          <TextBlock Text="{Binding Statistics.Remaining, StringFormat='{0:mm\\:ss}'}"
                     FontSize="16" FontWeight="Bold"
                     HorizontalAlignment="Right" />
        </StackPanel>
      </Grid>
    </StackPanel>

    <!-- 按钮区域 -->
    <Border Grid.Row="2" Height="50"
            Background="#F5F5F5" Padding="16,0">
      <StackPanel Orientation="Horizontal"
                  HorizontalAlignment="Right" Spacing="8">
        <lui:LayButton Command="{Binding StartCommand}"
                       Content="开始更新"
                       Type="Primary"
                       Width="100" Height="32" />
        <lui:LayButton Command="{Binding RestartCommand}"
                       Content="重新下载"
                       Width="90" Height="32" />
      </StackPanel>
    </Border>

  </Grid>
</lui:LayWindow>
