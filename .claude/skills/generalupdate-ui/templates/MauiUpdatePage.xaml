<!--
【Skill 自动生成】MAUI Android 更新页面
基于 .NET MAUI + CommunityToolkit.Mvvm
自动支持深色/浅色模式（AppThemeBinding）

使用方式：
  1. 安装 NuGet: GeneralUpdate.Maui.Android
  2. 添加本页面到 Pages/ 目录
  3. 在 MauiProgram.cs 注册 DI
-->
<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:MauiUpdate.ViewModels"
             x:Class="MauiUpdate.Pages.UpdatePage"
             x:DataType="vm:UpdateViewModel"
             Title="软件更新"
             BackgroundColor="{AppThemeBinding Light={StaticResource White},
                                               Dark={StaticResource Black}}">

  <ScrollView>
    <VerticalStackLayout Spacing="20" Padding="24"
                         VerticalOptions="Center">

      <!-- 图标 -->
      <Border StrokeShape="RoundRectangle 32"
              BackgroundColor="{AppThemeBinding Light={StaticResource Primary},
                                                Dark={StaticResource PrimaryDark}}"
              HeightRequest="64" WidthRequest="64"
              HorizontalOptions="Center">
        <Label Text="🔄" FontSize="32"
               HorizontalOptions="Center"
               VerticalOptions="Center" />
      </Border>

      <!-- 标题 -->
      <Label Text="发现新版本"
             FontSize="24" FontAttributes="Bold"
             HorizontalOptions="Center"
             TextColor="{AppThemeBinding Light={StaticResource Black},
                                          Dark={StaticResource White}}" />

      <!-- 版本号 -->
      <Label Text="{Binding VersionText}"
             FontSize="14"
             HorizontalOptions="Center"
             TextColor="{AppThemeBinding Light=Gray, Dark=#AAAAAA}" />

      <!-- 更新说明 -->
      <Border StrokeShape="RoundRectangle 8"
              Padding="16"
              BackgroundColor="{AppThemeBinding Light=#F5F5F5,
                                                Dark=#2D2D2D}">
        <Label Text="{Binding ReleaseNotes}"
               FontSize="13"
               TextColor="{AppThemeBinding Light=#333333,
                                            Dark=#CCCCCC}" />
      </Border>

      <!-- 进度条 -->
      <ProgressBar Progress="{Binding ProgressValue}"
                   ProgressColor="{AppThemeBinding Light={StaticResource Primary},
                                                    Dark={StaticResource PrimaryDark}}"
                   HeightRequest="8" />

      <!-- 进度文本 -->
      <Label Text="{Binding StatusText}"
             FontSize="14"
             HorizontalOptions="Center"
             TextColor="{AppThemeBinding Light=Gray, Dark=#AAAAAA}" />

      <!-- 速度 -->
      <Label Text="{Binding SpeedText}"
             FontSize="12"
             HorizontalOptions="Center"
             TextColor="{AppThemeBinding Light=#999999, Dark=#777777}" />

      <!-- 按钮 -->
      <Button Text="开始更新"
              Command="{Binding StartUpdateCommand}"
              BackgroundColor="{AppThemeBinding Light={StaticResource Primary},
                                                Dark={StaticResource PrimaryDark}}"
              TextColor="White"
              CornerRadius="8"
              HeightRequest="48"
              FontSize="16"
              Margin="0,8,0,0" />

    </VerticalStackLayout>
  </ScrollView>
</ContentPage>
