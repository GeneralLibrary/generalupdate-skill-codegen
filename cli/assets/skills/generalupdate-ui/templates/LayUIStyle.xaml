<!--
[Skill Auto-generated] WPF + LayUI.Wpf Update Window
Based on LayUI.Wpf skin library. Replace MockDownloadService with RealDownloadService for real update drive.

Usage:
  1. Install NuGet: LayUI.Wpf
  2. Add RealDownloadService_Wpf.cs (adapted from RealDownloadService.cs)
  3. Reference LayUI.Wpf theme in App.xaml
  4. Add this file to Views/
-->
<lui:LayWindow x:Class="Upgrade.WPF.Views.UpdateWindow"
               xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
               xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
               xmlns:lui="clr-namespace:LayUI.Wpf.Controls;assembly=LayUI.Wpf"
               xmlns:vm="clr-namespace:Upgrade.WPF.ViewModels"
               Title="Software Update"
               Height="350" Width="500"
               WindowStartupLocation="CenterScreen"
               ResizeMode="CanMinimize"
               Icon="/Resources/update.ico"
               lui:LayWindowHelper.IsTitleAcross="False">

  <Window.Resources>
    <Style TargetType="TextBlock" x:Key="InfoText">
      <Setter Property="FontSize" Value="13" />
      <Setter Property="Foreground" Value="#666666" />
      <Setter Property="Margin" Value="0,2" />
    </Style>
  </Window.Resources>

  <Grid Margin="0,0,0,0">
    <Grid.RowDefinitions>
      <RowDefinition Height="Auto" />
      <RowDefinition Height="*" />
      <RowDefinition Height="Auto" />
    </Grid.RowDefinitions>

    <!-- Title Area -->
    <Border Grid.Row="0" Height="60"
            Background="{DynamicResource PrimaryBrush}"
            Padding="20,0">
      <StackPanel VerticalAlignment="Center">
        <TextBlock Text="New Version Available"
                   FontSize="20" FontWeight="Bold"
                   Foreground="White" />
        <TextBlock Text="{Binding Statistics.Version, StringFormat='Version: {0}'}"
                   FontSize="13"
                   Foreground="#CCFFFFFF" />
      </StackPanel>
    </Border>

    <!-- Content Area -->
    <StackPanel Grid.Row="1" Margin="32,24" Spacing="16"
                VerticalAlignment="Center">

      <!-- Progress Status -->
      <TextBlock Text="{Binding StatusText}"
                 FontSize="16" FontWeight="SemiBold"
                 HorizontalAlignment="Center" />

      <!-- Progress Bar (LayUI Style) -->
      <Border Height="8" CornerRadius="4"
              Background="#E8E8E8">
        <Border Height="8" CornerRadius="4"
                Width="{Binding Statistics.ProgressPercentage, Converter={StaticResource PercentToWidthConverter}}"
                Background="{DynamicResource PrimaryBrush}" />
      </Border>

      <!-- Statistics Info -->
      <Grid Margin="0,8,0,0">
        <Grid.ColumnDefinitions>
          <ColumnDefinition Width="*" />
          <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>
        <StackPanel Grid.Column="0">
          <TextBlock Text="Download Speed"
                     Style="{StaticResource InfoText}" />
          <TextBlock Text="{Binding Statistics.Speed, StringFormat='{0:F1} MB/s'}"
                     FontSize="16" FontWeight="Bold" />
        </StackPanel>
        <StackPanel Grid.Column="1">
          <TextBlock Text="Remaining Time"
                     Style="{StaticResource InfoText}"
                     HorizontalAlignment="Right" />
          <TextBlock Text="{Binding Statistics.Remaining, StringFormat='{0:mm\\:ss}'}"
                     FontSize="16" FontWeight="Bold"
                     HorizontalAlignment="Right" />
        </StackPanel>
      </Grid>
    </StackPanel>

    <!-- Button Area -->
    <Border Grid.Row="2" Height="50"
            Background="#F5F5F5" Padding="16,0">
      <StackPanel Orientation="Horizontal"
                  HorizontalAlignment="Right" Spacing="8">
        <lui:LayButton Command="{Binding StartCommand}"
                       Content="Start Update"
                       Type="Primary"
                       Width="100" Height="32" />
        <lui:LayButton Command="{Binding RestartCommand}"
                       Content="Restart Download"
                       Width="90" Height="32" />
      </StackPanel>
    </Border>

  </Grid>
</lui:LayWindow>
